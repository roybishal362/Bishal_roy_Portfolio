# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local — it is gitignored on purpose.
# On Vercel, add these same names under Project → Settings → Environment Variables.

# Anthropic — powers the chat (primary). https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Groq — automatic fallback if Anthropic is unavailable. https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ElevenLabs — natural voice for voice mode (optional).
# Without this, voice mode still works using the browser's built-in speech,
# which sounds robotic. https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional: a specific voice. Default is a natural male English voice.
# Put your OWN cloned voice id here once you've created one.
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
